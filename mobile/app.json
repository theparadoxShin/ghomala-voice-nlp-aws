{
  "expo": {
    "name": "NAM SA'",
    "slug": "nam-sa-nova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/playstore.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/playstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daemoncraft.namsa",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NAM SA' needs access to your microphone for voice conversations in Ghomala'.",
        "NSSpeechRecognitionUsageDescription": "NAM SA' uses speech recognition to understand Ghomala' and French."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.daemoncraft.namsa",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/playstore.png"
    },
    "extra": {
      "API_URL": "http://nam-sa-alb-1826409243.us-east-1.elb.amazonaws.com",
      "eas": {
        "projectId": "e336475c-411a-4882-b2a5-ca291f6df9a1"
      }
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "NAM SA' a besoin de ton micro pour les conversations en Ghomala'."
        }
      ],
      "expo-asset",
      "expo-localization"
    ],
    "owner": "theparadoxe"
  }
}
