{
  "expo": {
    "name": "NAM SA'",
    "slug": "nam-sa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/playstore.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/playstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daemoncraft.namsa",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NAM SA' needs access to your microphone for voice conversations in Ghomala'.",
        "NSSpeechRecognitionUsageDescription": "NAM SA' uses speech recognition to understand Ghomala' and French."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.daemoncraft.namsa",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/playstore.png"
    },
    "extra": {
      "API_URL": "https://nam-sa-976647416990.us-central1.run.app"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "NAM SA' a besoin de ton micro pour les conversations en Ghomala'."
        }
      ],
      "expo-asset",
      "expo-localization"
    ]
  }
}
