# NAM SA' Backend Configuration
AWS_REGION=us-east-1

# Model IDs (replace after fine-tuning)
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0
NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0

# After fine-tuning, use your custom model ARN:
# NOVA_LITE_MODEL_ID=arn:aws:bedrock:us-east-1:ACCOUNT_ID:custom-model/YOUR_MODEL_NAME

# Server
PORT=8000
LOG_LEVEL=info
